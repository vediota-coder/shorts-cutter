# ────────────────────────────────────────────────────────────────────────
# .env.example — шаблон. Скопировать в .env и заполнить нужными значениями.
# .env в .gitignore — РЕАЛЬНЫЕ значения никогда не попадут в repo.
# ────────────────────────────────────────────────────────────────────────

# ── LLM провайдеры (нужен один; default — claude-code CLI без ключа) ────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...                    # для transcribe (см. ниже)

# ── Transcribe backend override ────────────────────────────────────────
# По умолчанию выбирается mlx (Mac arm64) / faster-whisper (CPU/CUDA).
# Поставьте groq если хотите ускорение через Groq Cloud (~$0.18 за 30-мин видео).
# EXCELLA_TRANSCRIBE_BACKEND=groq

# ── ElevenLabs voiceover (опц) ─────────────────────────────────────────
# ELEVENLABS_API_KEY=...

# ── Pexels b-roll картинки (опц) ───────────────────────────────────────
# PEXELS_API_KEY=...

# ── HuggingFace gated models (опц) ─────────────────────────────────────
# HF_TOKEN=hf_...

# ── Pipeline настройки ──────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=2                     # лимит параллельных задач
EXCELLA_STREAMING_ANALYZE=1               # 1 проход декодирования (1.6× быстрее)
# EXCELLA_DEV=1                           # ОТКЛЮЧАЕТ tamper detection — только dev

# ── Кэш analysis (по умолчанию ~/.excella/cache/analysis) ──────────────
# EXCELLA_CACHE_DIR=/path/to/cache
